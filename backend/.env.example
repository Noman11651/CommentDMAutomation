VERIFY_TOKEN=your_verify_token_here
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token_here
IG_BUSINESS_ACCOUNT_ID=your_ig_business_account_id_here

# Comma-separated frontend origins (required for browser + credentials). Do not use * here.
# CORS_ORIGINS=https://commentdmautomationfrontend.vercel.app,http://localhost:3000
# Optional regex for extra origins. On Vercel, *.vercel\.app is allowed by default when unset.
# Set CORS_ORIGIN_REGEX= (empty) in the project env to disable the default and use CORS_ORIGINS only.

# --- Persistent reel config (Vercel KV or Upstash Redis REST) ---
# If KV_REST_API_URL + KV_REST_API_TOKEN are set (Vercel KV), or UPSTASH_REDIS_REST_URL +
# UPSTASH_REDIS_REST_TOKEN (Upstash), config is stored in Redis and survives cold starts.
# Leave unset for local file storage (backend/reels_config.json).
# CONFIG_STORAGE=file   # force JSON file even if KV env is set
# CONFIG_STORAGE=redis  # force KV; fails fast if URL/token missing
# REELS_CONFIG_KV_KEY=commentdm:reels_config_v1
# CONFIG_BOOTSTRAP_FILE=/absolute/path/reels_config.json  # optional: import JSON into KV once when empty
